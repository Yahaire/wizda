{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Scraper Seed",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": [
                "prisma",
                "db",
                "seed"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**",
                "${workspaceFolder}/node_modules/**"
            ],
            "sourceMaps": true,
            "env": {
                "NODE_ENV": "development"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Debug Web Client",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/packages/web-client",
            "preLaunchTask": "npm: dev:web-client",
            "postDebugTask": "Terminate Next.js Dev Server",
            "sourceMaps": true,
            "trace": true,
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Start DB",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev:db",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug API",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": ["tsx", "watch"],
            "args": ["src/index.ts"],
            "cwd": "${workspaceFolder}/packages/backend-api",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "restart": true,
            "sourceMaps": true,
            "skipFiles": [
                "<node_internals>/**",
                "${workspaceFolder}/node_modules/**"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    ],
    "compounds": [
        {
            "name": "Debug Full Stack",
            "configurations": ["Start DB", "Debug API", "Debug Web Client"]
        }
    ]
}
