{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Environment Settings
    "module": "commonjs",
    "moduleResolution": "node10",
    "rootDir": "..",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@app/*": ["./src/*"],
      "@local-prisma/*": ["./prisma/*"],
      "@shared/*": ["../shared/src/*"],
    },

    // Output
    "outDir": "./dist",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Keep your strictness preferences
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "include": [
    "src/**/*",
    "prisma/seed-from-html/**/*",
    "prisma/generated/**/*",
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
}