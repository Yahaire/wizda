# Where the seed pulls its data from. Each can be a remote URL or a local file
# path to a downloaded copy (see packages/backend-api/prisma/seed-from-html).
JUNK_DROP_RATES_SOURCE_URL="https://wizardry.info/daphne/gacha_rates/en/equipments.html"
EQUIPMENT_BLESSING_DROP_RATES_SOURCE_URL="https://wizardry.info/daphne/gacha_rates/en/alternations.html"
# Fasterthoughts equipment taxonomy CSVs (weapons + armor) — the source of each
# item's category + rank, matched to our equipment by name. Thanks to
# Fasterthoughts and NRJank for maintaining them.
WEAPON_TAXONOMY_SOURCE_URL="https://raw.githubusercontent.com/itsnicksia/wizardry-daphne-guide/main/data/weapon.csv"
ARMOR_TAXONOMY_SOURCE_URL="https://raw.githubusercontent.com/itsnicksia/wizardry-daphne-guide/main/data/armor.csv"

DATABASE_URL="postgresql://wizda_user:yourpassword@localhost:5432/wizda"

WEB_CLIENT_URL="http://localhost:3000"
# Where the web-client's `/api/*` rewrite proxies to. NOTE: the web-client bakes
# this into the build (`next build` writes it into .next/routes-manifest.json),
# so changing it in production needs a web REBUILD, not just a restart.
API_URL="http://localhost:3001"

# Port the backend API listens on. Defaults to 3001. Override only to avoid a
# collision — e.g. on a shared server where another app already holds 3001. The
# frontend's port isn't set here; it comes from `next start -p <port>`.
# PORT="3001"

# Interface the backend API binds to. Defaults to 127.0.0.1 (loopback-only) so
# the raw Node port is never reachable from the internet — in production the API
# is served solely through Apache's reverse proxy. Leave unset unless you have a
# reason to change it.
# HOST="127.0.0.1"

# --- Analytics (Umami) — all optional; blank = analytics disabled (dormant) ---
# Client-side pageviews: the Umami website id for the web-client. Blank => no script.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
# First-party proxy targets so /umami/* is served same-origin (dodges ad-blockers).
# Set BOTH to enable the /umami/script.js and /umami/api/send rewrites.
UMAMI_SCRIPT_URL=""   # e.g. https://analytics.example.com/script.js
UMAMI_COLLECT_URL=""  # e.g. https://analytics.example.com/api/send
# Server-side custom events (a SECOND Umami site) for API usage (guarantee_query).
UMAMI_API_URL=""            # base URL of the Umami instance, e.g. https://analytics.example.com
UMAMI_API_WEBSITE_ID=""     # the API-events website's UUID
UMAMI_COLLECT_ENDPOINT=""   # defaults to /api/send if blank
